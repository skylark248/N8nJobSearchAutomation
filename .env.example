# Job Search Automation - Environment Variables
# Copy this file to .env and fill in your values
# Note: These are for YOUR reference only. Credentials are configured inside n8n, not read from this file.

# SerpAPI (Google Jobs search)
# Get your key at: https://serpapi.com/dashboard
# Free tier: 100 searches/month
SERPAPI_API_KEY=your_serpapi_key_here

# Google Gemini API (Gemini 2.0 Flash for scoring + cover letters)
# Get your key at: https://aistudio.google.com/apikey
# Cost: $0 (free tier: 15 RPM, 1M tokens/day)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth2 (Google Sheets + Gmail)
# Set up at: https://console.cloud.google.com
# Enable: Google Sheets API + Gmail API
# Create OAuth2 credentials with redirect URI: http://localhost:5678/rest/oauth2-credential/callback
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Your email (for receiving job digest)
YOUR_EMAIL=your_email@gmail.com

# Google Sheet ID (created during setup)
GOOGLE_SHEET_ID=your_sheet_id_here
